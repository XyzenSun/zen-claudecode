{ 
  "statusLine": {
    "type": "command", 
    "command": "~/.claude/ccline/ccline.exe",
    "padding": 0
  },
  "language": "chinese",
  "disableAllHooks": false,
  "autoCompact": false,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_STREAM_IDLE_TIMEOUT_MS": 480000,
    "MCP_TIMEOUT":120000,
    "API_TIMEOUT_MS": 1200000,
    "BASH_DEFAULT_TIMEOUT_MS": 300000,
    "BASH_MAX_TIMEOUT_MS": 1800000
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git pull:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(cat:*)",
      "Bash(type:*)",
      "Bash(find:*)",
      "Bash(findstr:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(where:*)",
      "Bash(whoami:*)",
      "Bash(tree:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Glob",
      "Grep",
      "LS",
      "Read",
      "WebFetch",
      "WebSearch",
      "mcp__context7",
      "mcp__exa",
      "mcp__tavily"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rd /s:*)",
      "Bash(del /f:*)",
      "Bash(del /s:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(sudo:*)",
      "Bash(runas:*)",
      "Bash(powershell -ExecutionPolicy Bypass:*)",
      "Bash(powershell -ep bypass:*)",
      "Bash(curl *|*(bash|sh):*)",
      "Bash(wget *|*sh:*)",
      "Bash(Invoke-WebRequest*|*iex:*)",
      "Bash(IEX:*)",
      "Bash(format:*)",
      "Bash(diskpart:*)",
      "Bash(shutdown:*)",
      "Bash(net user:*)",
      "Bash(net localgroup:*)",
      "Bash(reg delete:*)",
      "Bash(reg add:*)",
      "Bash(schtasks /create:*)",
      "Bash(icacls * /grant Everyone:*)",
      "Bash(attrib:*)",
      "Bash(move C:\\:*)",
      "Bash(move C\\\\:*)",
      "Bash(mv /*:*)",
      "Write(~/.ssh/*)",
      "Write(%USERPROFILE%/.ssh/*)"
    ],
    "ask": [
      "Edit(*)",
      "Write(*)",
      "Edit(*.env)",
      "Bash(rm:*)",
      "Bash(del:*)",
      "Bash(rmdir:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git checkout --:*)",
      "Bash(git branch -D:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)",
      "Bash(taskkill /f:*)",
      "Bash(taskkill /F:*)"
    ]
  }
}
