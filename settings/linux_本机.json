{ 
  "statusLine": {
    "type": "command", 
    "command": "~/.claude/ccline/ccline",
    "padding": 0
  },
  "language": "chinese",
  "disableAllHooks": false,
  "autoCompact": false,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_STREAM_IDLE_TIMEOUT_MS": 480000,
    "MCP_TIMEOUT": 120000,
    "API_TIMEOUT_MS": 1200000,
    "BASH_DEFAULT_TIMEOUT_MS": 300000,
    "BASH_MAX_TIMEOUT_MS": 1800000
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git pull:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(tree:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Glob",
      "Grep",
      "LS",
      "Read",
      "WebFetch",
      "WebSearch",
      "mcp__context7",
      "mcp__exa",
      "mcp__tavily"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(curl *|*(bash|sh):*)",
      "Bash(wget *|*sh:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(useradd:*)",
      "Bash(usermod:*)",
      "Bash(userdel:*)",
      "Bash(groupadd:*)",
      "Bash(groupmod:*)",
      "Bash(groupdel:*)",
      "Bash(crontab:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chown:*)",
      "Bash(chattr:*)",
      "Bash(mv /*:*)",
      "Write(~/.ssh/*)"
    ],
    "ask": [
      "Edit(*)",
      "Write(*)",
      "Edit(*.env)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git checkout --:*)",
      "Bash(git branch -D:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)",
      "Bash(kill -9:*)",
      "Bash(killall:*)"
    ]
  }
}
