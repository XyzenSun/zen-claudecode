{   
  "autoCompact": true,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "false",
    "CLAUDE_STREAM_IDLE_TIMEOUT_MS": 480000,
    "MCP_TIMEOUT":120000,
    "API_TIMEOUT_MS": 1200000,
    "BASH_DEFAULT_TIMEOUT_MS": 300000,
    "BASH_MAX_TIMEOUT_MS": 1800000
  },
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(init 0:*)",
      "Bash(init 6:*)",
      "Bash(mv /*:*)",
      "Bash(mkfs*:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(dd if=* of=/dev/sd*:*)",
      "Bash(dd if=* of=/dev/vd*:*)"
    ]
  }


}